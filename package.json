{
  "name": "planilhas",
  "displayName": "Planilhas",
  "description": "Visualize arquivos CSV, XLS e XLSX no VS Code",
  "version": "0.0.1",
  "publisher": "ibict",
  "icon": "logo.png",
  "license": "Apache-2.0",
  "engines": { "vscode": "^1.70.0" },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "planilhas.spreadsheetEditor",
        "displayName": "Planilhas Viewer",
        "selector": [
          { "filenamePattern": "*.csv" },
          { "filenamePattern": "*.xls" },
          { "filenamePattern": "*.xlsx" }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js && node scripts/copy-media.js",
    "watch": "node esbuild.js --watch",
    "package": "node scripts/copy-media.js && npx @vscode/vsce package --out ./build --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.20.0",
    "@vscode/vsce": "^2.24.0"
  },
  "dependencies": {
    "x-data-spreadsheet": "^1.1.9",
    "xlsx": "0.18.5"
  }
}
